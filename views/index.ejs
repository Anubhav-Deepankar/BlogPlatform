<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog platform</title>
  </head>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

  <style>
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      background-color: chocolate;
      font-family: cursive;
      padding:40px;
    }
    h1{
      margin: 20px;
    }
    ul{
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      align-items:flex-start;
    }
    li {
      margin: 1rem;
      border: 2px solid rgb(0, 0, 0);
      padding: 1.5rem;
      background-color: antiquewhite;
      border-radius: 17px;
      width: 400px;
      overflow: hidden;
      
      
    }
    
    .anchors {
      display: flex;
      margin-top: 10px;
      margin-bottom: 10px;
    }
    .anchors a{
        margin-right: 10px;
    }
  </style>
  <body>
    <h1>Showing All comments</h1>
    <form action="/comments" method="GET" class="d-flex mb-4" style="width:400px;">
  
      <input 
        type="text" 
        name="user"
        placeholder="Search by username..."
        class="form-control me-2"
      >
    
      <button class="btn btn-dark">Search</button>
    
    </form>
    <ul>
      <%for(let comment of comments){ %>

      <li>
        <strong><%= comment.user %></strong> : <%= comment.text %>
        <div class="anchors">
          <a href="/comments/<%= comment.id %>"> <button class="btn btn-success">Show</button></a>
          <a href="/comments/<%= comment.id %>/edit"> <button class="btn btn-secondary">Edit</button></a>
        </div>
        <form action="/comments/<%= comment.id %>?_method=DELETE" method="post">
          <button class="btn btn-danger">Delete</button>
        </form>
      </li>
      <% } %>
    </ul>
    <a href="/comments/new" style="text-decoration: none;color: black;"><button class="btn btn-warning">Add a new comment</a>
  </body>
</html>
