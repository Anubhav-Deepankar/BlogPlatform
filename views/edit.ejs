<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit responses</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>

<style>
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      background-color: chocolate;
      font-family: cursive;
      padding: 40px;
    }
    input[type="text"] {
      border: 2px solid black;
      border-radius: 17px;
    }
</style>



<body>

    <h2> Edit form </h2>

    
    <form action="/comments/<%= comment.id %>?_method=PATCH" method="post">
        <br>
        <div>
            <label for="user">Username</label>
            <input type="text" name="user" id="user" placeholder="Username" style="text-align: center;" value="<%= comment.user %>">
        </div>
        <br>
        <div>
            <label for="text">Comment Text</label>
            <br><br>
           <textarea name="text" id="text" cols="40" rows="10"><%= comment.text %></textarea>
        </div>

        <button class="btn btn-success"> Update Comment</button>
       
    </form>


    
    
</body>
</html>